# Required: 64-char hex string for AES-256-GCM encryption key derivation
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Optional: Redis connection URL (defaults to localhost:6379)
REDIS_URL=redis://localhost:6379

# Optional: Maximum note content length in bytes (default: 102400 = 100 KB)
MAX_NOTE_LENGTH=102400

# Optional: Default TTL in seconds (default: 604800 = 7 days)
DEFAULT_TTL=604800

# Whitelabel branding (all optional — unset = GoneNote defaults)
# APP_NAME=MyBrand
# APP_LOGO_URL=https://cdn.example.com/logo.svg
# APP_COLOR_ROOT=#0a0a0f
# APP_COLOR_SURFACE=#16161d
# APP_COLOR_ELEVATED=#1c1c24
# APP_COLOR_PRIMARY=#e4e4ec
# APP_COLOR_SECONDARY=#9494a4
# APP_COLOR_MUTED=#5c5c6e
# APP_COLOR_ACCENT=#3dd6c8
# APP_COLOR_ACCENT_HOVER=#5cdfd4
# APP_COLOR_SUCCESS=#4ade80
# APP_COLOR_ERROR=#fbbf24
